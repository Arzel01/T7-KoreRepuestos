# ============================================================================
# Kore Repuestos — Frontend Móvil (React Native)
# Copiar a .env y a .env.production según sea necesario.
# Para que React Native lea estas variables se usa `react-native-config`.
# ============================================================================

# URL base de la API (incluye prefijo /api/v1)
# IMPORTANTE: en Android emulator, localhost del host = 10.0.2.2
# En iOS simulator sí funciona localhost.
API_BASE_URL=http://10.0.2.2:3000/api/v1

# Identidad de la app
APP_NAME=Kore Repuestos
APP_VERSION=0.1.0
APP_ENV=development

# Deep links / scheme
APP_SCHEME=kore

# Feature flags
FEATURE_OFFLINE_MODE=false
FEATURE_PUSH_NOTIFICATIONS=true

# Observabilidad opcional
SENTRY_DSN=
