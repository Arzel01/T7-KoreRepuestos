# ============================================================================
# Kore Repuestos — Frontend Web (React + Vite)
# Copiar a .env.local para desarrollo local.
# Vite expone al cliente SOLO las variables con prefijo VITE_.
# ============================================================================

# URL base de la API (incluye prefijo /api/v1)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Identidad de la app
VITE_APP_NAME=Kore Repuestos
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# Feature flags (true/false)
VITE_FEATURE_MAINTENANCE_CALCULATOR=true
VITE_FEATURE_DARK_MODE=true

# Observabilidad opcional
VITE_SENTRY_DSN=
