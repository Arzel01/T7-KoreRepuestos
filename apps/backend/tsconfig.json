{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@kore/shared": ["../../packages/shared/dist/index"],
      "@kore/shared/*": ["../../packages/shared/dist/*"]
    },
    "strictNullChecks": true,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": [
    "src/**/*",
    "test/product-detail.e2e-spec.ts",
    "test/products-deactivate.e2e-spec.ts",
    "test/product.entity.e2e-spec.ts"
  ],
  "exclude": ["node_modules", "dist", "test"]
}
