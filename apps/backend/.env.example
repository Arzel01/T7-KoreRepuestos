# ============================================================================
# Kore Repuestos — Backend (NestJS)
# Copiar a .env y rellenar con valores reales del entorno local.
# NUNCA commitear el archivo .env real.
# ============================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
API_BASE_URL=http://localhost:3000

# --- Base de datos (Supabase PostgreSQL) ---
# Dashboard → Project Settings → Database → Connection string → URI
#
# Direct Connection (puerto 5432) — usar siempre para migraciones y desarrollo.
# TypeORM usa prepared statements: incompatibles con Transaction Mode (6543).
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Transaction Mode / pgBouncer (puerto 6543) — recomendado en producción
# cuando se despliega en entornos serverless o con muchas conexiones cortas.
DATABASE_TRANSACTION_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
DB_LOGGING=true
DB_SYNCHRONIZE=false
# Validar el certificado SSL del servidor (true = seguro, default).
# Cambiar a false solo si el entorno no tiene ca-certificates actualizados (Alpine antiguo, etc.).
DB_SSL_REJECT_UNAUTHORIZED=true

# --- Supabase ---
# Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
# ATENCIÓN: NUNCA exponer SUPABASE_SERVICE_ROLE_KEY al cliente (browser/mobile).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- JWT (autenticación) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-secret-min-32-chars-please
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-secret-for-refresh
JWT_REFRESH_EXPIRES_IN=7d

# --- Seguridad / bcrypt ---
BCRYPT_SALT_ROUNDS=10

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# --- Throttling / Rate limit ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Logging ---
LOG_LEVEL=debug

# --- Swagger (documentación de API) ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
