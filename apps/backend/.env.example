# ============================================================================
# Kore Repuestos — Backend (NestJS)
# Copiar a .env y rellenar con valores reales del entorno local.
# NUNCA commitear el archivo .env real.
# ============================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
API_BASE_URL=http://localhost:3000

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kore_user
DB_PASSWORD=kore_password
DB_NAME=kore_repuestos
# En desarrollo conviene desactivar synchronize y usar migraciones explícitas
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# --- JWT (autenticación) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-secret-min-32-chars-please
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-secret-for-refresh
JWT_REFRESH_EXPIRES_IN=7d

# --- Seguridad / bcrypt ---
BCRYPT_SALT_ROUNDS=10

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# --- Throttling / Rate limit ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Logging ---
LOG_LEVEL=debug

# --- Swagger (documentación de API) ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
